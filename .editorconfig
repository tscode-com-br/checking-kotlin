root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_import-ordering = disabled
ktlint_standard_annotation = disabled
