<?xml version="1.0" encoding="utf-8"?>
<!--
  Production network security config: HTTPS only (no cleartext allowed).
  The debug source-set overrides this file to allow cleartext to 10.0.2.2 (§5).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
