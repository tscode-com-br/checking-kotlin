<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== Networking ===== -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ===== Location (foreground baseline) ===== -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- ===== Background automatic activities (§23) ===== -->
    <!-- Background location — "Allow all the time"; requested via the permission ladder (§23.6). -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on Android 14+ for location-type foreground services. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Local push notifications for activity events and auth-expiry prompt (§23.9). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Restart the background engine after reboot or app update (§23.3-4). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Battery-optimization exemption dialog; prevents Doze from throttling the FGS (§23.6-4). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Wake lock held for the duration of each background evaluation burst (§23.10). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- NOTE: no exact-alarm permission. USE_EXACT_ALARM is reserved by Google Play for
         alarm-clock/calendar apps, which Checking is not. The Scheduled Pause resume uses
         inexact-but-while-idle alarms (setAndAllowWhileIdle) instead — see
         BackgroundCheckOrchestrator.scheduleExactWake, which already falls back to inexact. -->

    <!-- ===== Camera / microphone (accident video, §12.3) ===== -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Declare camera/mic as OPTIONAL features. Without these, Google Play infers the CAMERA
         and RECORD_AUDIO permissions imply REQUIRED hardware, excluding devices without an
         autofocus camera or microphone (~tablets) — a regression vs. the previous Flutter
         release, which requested neither permission. Accident video gates these at runtime. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:name=".CheckingApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Checking"
        android:networkSecurityConfig="@xml/network_security_config"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules">

        <!-- ===== Main Activity ===== -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Checking.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== Background automatic activities (§23.12) ===== -->

        <!-- Foreground service hosting the 15-min location engine (§23.3-1). -->
        <service
            android:name=".platform.background.AutoActivityForegroundService"
            android:foregroundServiceType="location"
            android:exported="false"
            android:stopWithTask="false" />

        <!-- Hilt + WorkManager: remove WorkManager's default startup initializer so it uses
             on-demand initialization via CheckingApp's Configuration.Provider (HiltWorkerFactory).
             Without this the library's default initializer runs before Hilt and uses the default
             WorkerFactory, so @HiltWorker workers fail with NoSuchMethodException. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Boot + package-replaced receiver — restores the FGS after reboot/update (§23.3-4). -->
        <receiver
            android:name=".platform.background.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Geofence wake-up receiver — delivers ENTER/EXIT/DWELL from a PendingIntent (§23.3-2). -->
        <!-- exported="false" is sufficient: Play Services fires via the PendingIntent we own,
             so it does not send a direct broadcast and needs no broadcaster permission. -->
        <receiver
            android:name=".platform.background.GeofenceBroadcastReceiver"
            android:exported="false" />

    </application>

</manifest>
