# keystore.properties — Release signing configuration
#
# Copy this file to keystore.properties (git-ignored) and fill in real values.
# Referenced by app/build.gradle.kts via keystoreProperties.
#
# VERSION BUMP POLICY
# -------------------
# versionCode:  increment by 1 for every Play Store submission (never reuse).
#               Set via Gradle property: ./gradlew -Pchecking.versionCode=18 bundleRelease
# versionName:  semver (MAJOR.MINOR.PATCH-CHANNEL), e.g. 2.0.1 or 2.1.0-beta.
#               Set via Gradle property: ./gradlew -Pchecking.versionName=2.0.1 bundleRelease
# Defaults (when properties are absent): versionCode=17, versionName=2.0.0-alpha
#
# HOW TO GENERATE A KEYSTORE
# ---------------------------
# keytool -genkeypair -v \
#   -keystore checking-release.jks \
#   -alias checking-key \
#   -keyalg RSA -keysize 2048 -validity 10000 \
#   -storepass <storePassword> -keypass <keyPassword>
#
# HOW TO USE IN CI (GitHub Actions)
# ----------------------------------
# 1. Base64-encode the keystore: base64 -i checking-release.jks | pbcopy
# 2. Add GitHub secrets: KEYSTORE_BASE64, KEYSTORE_STORE_PASSWORD,
#                        KEYSTORE_KEY_ALIAS, KEYSTORE_KEY_PASSWORD
# The CI workflow (.github/workflows/android.yml) decodes and writes keystore.properties
# automatically on tag builds.

storeFile=change-me
storePassword=change-me
keyAlias=change-me
keyPassword=change-me
